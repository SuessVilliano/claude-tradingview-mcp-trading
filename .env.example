# ──────────────────────────────────────────────────────────────────────
# HYBRID AI — Trading & Briefing Configuration
# ──────────────────────────────────────────────────────────────────────

# Symbol + timeframe.
# Optimized Auto Hybrid AI is tuned for the 10-minute on NQ / NAS100.
SYMBOL=NAS100
TIMEFRAME=10

# Paper trading is FORCED ON until you validate ≥30 paper signals.
# Flip to false only after you've reviewed the trade log and you're confident.
PAPER_TRADING=true

# Portfolio + guardrails
PORTFOLIO_VALUE_USD=10000
MAX_TRADE_SIZE_USD=500
MAX_TRADES_PER_DAY=3
RISK_PER_TRADE_PCT=0.5

# ──────────────────────────────────────────────────────────────────────
# WEBHOOK SERVER — receives alerts from TradingView Hybrid AI Pine scripts
# ──────────────────────────────────────────────────────────────────────
WEBHOOK_PORT=3000
TV_WEBHOOK_SECRET=                    # set a long random string; required to call /tv-webhook
ALERT_FROM=Hybrid AI <onboarding@resend.dev>

# ──────────────────────────────────────────────────────────────────────
# ALERTS — get pinged on every signal, TP, and SL
# ──────────────────────────────────────────────────────────────────────
ALERT_EMAIL=suessvilliano@gmail.com
ALERT_WEBHOOK_URL=                    # optional — Discord/Slack/n8n/GHL webhook
RESEND_API_KEY=                       # https://resend.com — free tier covers alerts

# ──────────────────────────────────────────────────────────────────────
# DAILY BRIEFING — emails you bias + key levels + news + econ + sentiment
# every morning before the open
# ──────────────────────────────────────────────────────────────────────
DAILY_BRIEFING_ENABLED=true
DAILY_BRIEFING_TIME=08:00             # 24h local time (HH:MM)
TIMEZONE=America/New_York

# AI provider for briefing + setup evaluation
# Use Anthropic for best reasoning, Vercel AI Gateway for unified billing.
AI_PROVIDER=anthropic                 # anthropic | openai | gateway
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_GATEWAY_API_KEY=
AI_MODEL=claude-sonnet-4-5

# Market data + news sources used by the daily briefing
POLYGON_API_KEY=                      # https://polygon.io — equities/index data
NEWS_API_KEY=                         # https://newsapi.org or finnhub.io
APIFY_API_KEY=                        # https://apify.com — optional, for transcripts/news scraping

# ──────────────────────────────────────────────────────────────────────
# Crypto execution (legacy — only used if you point this bot at a crypto pair)
# ──────────────────────────────────────────────────────────────────────
TRADE_MODE=spot
BITGET_API_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=
BITGET_BASE_URL=https://api.bitget.com
